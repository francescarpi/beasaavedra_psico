---
import type { Center } from '../../data/centers';
import { Icon } from 'astro-icon/components';

interface Props {
  center: Center;
}

const { center } = Astro.props;
---

<div class="bg-surface-container-low p-8 rounded-xl shadow-sm hover:shadow-md transition-shadow">
  <h4 class="text-xl font-serif text-primary mb-4">{center.name}</h4>
  <div class="space-y-3">
    <!-- Address -->
    <div class="flex items-start gap-3 text-on-surface-variant">
      <Icon
        name="material-symbols:location-on"
        class="text-primary-container text-xl flex-shrink-0"
        aria-hidden="true"
      />
      <p class="text-sm font-light">{center.address}</p>
    </div>
    <!-- Phone -->
    <div class="flex items-center gap-3 text-on-surface-variant">
      <Icon
        name="material-symbols:call"
        class="text-primary-container text-xl flex-shrink-0"
        aria-hidden="true"
      />
      <a
        class="text-sm font-medium hover:text-primary transition-colors"
        href={`tel:${center.phone}`}
      >{center.phoneDisplay}</a>
    </div>
  </div>
</div>
