---
import { t } from '../../i18n/utils';
import CenterCard from '../ui/CenterCard.astro';
import { centers } from '../../data/centers';
---

<section id="centers" class="py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-8">

    <!-- Section header -->
    <div class="text-center mb-20 space-y-4">
      <h2
        class="text-4xl md:text-5xl font-serif text-on-surface"
        data-i18n="centers.title"
      >{t('centers.title', 'ca')}</h2>
      <p
        class="text-on-surface-variant max-w-2xl mx-auto text-lg font-light"
        data-i18n="centers.subtitle"
      >{t('centers.subtitle', 'ca')}</p>
    </div>

    <!-- 3-col grid (lg), 2-col (md), 1-col (mobile) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {centers.map((center) => (
        <CenterCard center={center} />
      ))}
    </div>

  </div>
</section>
